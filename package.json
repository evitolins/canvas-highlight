{
  "name": "canvas-highlight",
  "version": "0.1.0",
  "description": "React component for canvas-based text highlighting with marker, pen, and rectangle renderers",
  "type": "module",
  "main": "./dist/canvas-highlight.cjs",
  "module": "./dist/canvas-highlight.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/canvas-highlight.js",
      "require": "./dist/canvas-highlight.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs/TECHNICAL.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit && tsc --noEmit --project tsconfig.test.json",
    "test:e2e": "playwright test"
  },
  "keywords": ["canvas", "highlight", "react", "marker", "annotation", "text-highlight", "highlighter", "mark"],
  "author": "Eriks Vitolins <evitolins@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evitolins/canvas-highlight.git"
  },
  "homepage": "https://github.com/evitolins/canvas-highlight",
  "bugs": {
    "url": "https://github.com/evitolins/canvas-highlight/issues"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
